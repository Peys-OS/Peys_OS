# ============================================
# Peys WhatsApp Bot Configuration
# ============================================

# Supabase Configuration (same as main app)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Blockchain Configuration
# Default: Base Sepolia testnet
RPC_URL=https://base-sepolia.g.alchemy.com/v2/your-api-key
ESCROW_CONTRACT_ADDRESS=0xa33dA56258829779BFbD56a6Be3f2712B79f16ca

# App URLs
APP_URL=https://peys-bot.vercel.app
FRONTEND_URL=https://peys-bot.vercel.app

# Server Configuration
PORT=3002
NODE_ENV=production

# ============================================
# WhatsApp Session Management
# ============================================
WHATSAPP_SESSION_PATH=./.waweb_auth
WHATSAPP_SESSION_BACKUP_PATH=./.waweb_auth/backup
SESSION_BACKUP_INTERVAL_MS=300000  # 5 minutes

# ============================================
# Reconnection Settings
# ============================================
MAX_RECONNECT_ATTEMPTS=10
RECONNECT_BASE_DELAY_MS=5000

# ============================================
# Message Queue Settings
# ============================================
MAX_MESSAGE_RETRIES=3
MESSAGE_RETRY_DELAY_1=5000   # 5 seconds
MESSAGE_RETRY_DELAY_2=30000   # 30 seconds
MESSAGE_RETRY_DELAY_3=120000  # 2 minutes

# ============================================
# Alerting Configuration
# ============================================
# Slack or Discord webhook URL for alerts
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Minimum alert level: debug, info, warning, error, critical
ALERT_MIN_LEVEL=info

# Cooldown between alerts (milliseconds)
ALERT_COOLDOWN_MS=300000  # 5 minutes

# ============================================
# Logging
# ============================================
LOG_LEVEL=info  # debug, info, warning, error
