
# Foundry Deployment Configuration
# Copy this to .env and fill in your values

# Your wallet private key (DO NOT COMMIT THIS!)
# For local testing with Anvil: 0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# TODO: Set this in your environment or use a secrets manager
PRIVATE_KEY=your_private_key_here

# For authentication
VITE_PRIVY_APP_ID=your_privy_app_id

# Polkadot RPC URLs (with fallbacks)
# Primary
POLKADOT_RPC=https://eth-asset-hub-paseo.dotters.network
# Fallbacks
POLKADOT_RPC_FALLBACK_1=https://paseo-rpc.dotters.network
POLKADOT_RPC_FALLBACK_2=https://westend-asset-hub-eth-rpc.polkadot.io

# Celo Alfajores RPC
CELO_ALFAJORES_RPC_URL=https://celo-sepolia.g.alchemy.com/v2/***REMOVED***

# Network to deploy to (use one of: polkadotHub, polkadotHubTestnet, moonbase)
# NOTE: The network name must match the RPC_URL variable name pattern
NETWORK=polkadotHubTestnet

# Map network name to RPC URL
polkadotHubTestnet_RPC_URL=https://eth-asset-hub-paseo.dotters.network

# Deployed Contract Addresses - Testnets

# Polkadot Asset Hub Testnet (Chain ID 420420421)
# USDC: Asset ID 1337 on Polkadot (EVM address not standard)
VITE_ESCROW_CONTRACT_ADDRESS_POLKADOT=0x0000000000000000000000000000000000000001
VITE_USDC_ADDRESS_POLKADOT=0x0000000000000000000000000000000000000001
VITE_USDT_ADDRESS_POLKADOT=0x0000000000000000000000000000000000000001

# Celo Alfajores Testnet (Chain ID 44787)
# RPC URL for deployment
# NOTE: Deployment requires funded wallet with CELO tokens
# Run: forge script contracts/script/DeployCeloAlfajores.s.sol --rpc-url celoAlfajores --broadcast --private-key YOUR_KEY
CELO_ALFAJORES_RPC_URL=https://celo-sepolia.g.alchemy.com/v2/***REMOVED***
# USDC: 0x2F25deB3848C207fc8E0c34035B3Ba7fC157602B (from Circle docs)
# TODO: Update after deployment
VITE_ESCROW_CONTRACT_ADDRESS_CELO=0x0000000000000000000000000000000000000001
VITE_USDC_ADDRESS_CELO=0x2F25deB3848C207fc8E0c34035B3Ba7fC157602B
VITE_USDT_ADDRESS_CELO=0x0000000000000000000000000000000000000001

# Base Sepolia Testnet (Chain ID 84532)
# Escrow: ***REMOVED*** (deployed 2026-03-11)
# USDC: 0x036CbD53842c5426634e7929541eC2318f3dCF7e (from Circle docs)
# NOTE: USDT is NOT available on Base Sepolia testnet - use only USDC
VITE_ESCROW_CONTRACT_ADDRESS_BASE_SEPOLIA=***REMOVED***
VITE_USDC_ADDRESS_BASE_SEPOLIA=0x036CbD53842c5426634e7929541eC2318f3dCF7e
VITE_USDT_ADDRESS_BASE_SEPOLIA=

# Default (for backwards compatibility) - Using Base Sepolia
VITE_ESCROW_CONTRACT_ADDRESS=***REMOVED***
VITE_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
VITE_USDT_ADDRESS=

