    "@fastify/swagger-ui": "^3.0.0",
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "ethers": "^6.11.0",
    "fastify": "^4.26.0",
    "ioredis": "^5.3.2",
    "jose": "^5.2.2",
    "nanoid": "^5.0.6",
    "pino-pretty": "^10.3.1",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
