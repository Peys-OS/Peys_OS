# Deployment Configuration
# Copy this file to .env and fill in your values

# Your wallet private key (DO NOT COMMIT THIS!)
PRIVATE_KEY=your_private_key_here

# RPC URLs
POLKADOT_HUB_RPC_URL=https://rpc.polkadot.io
POLKADOT_HUB_TESTNET_RPC_URL=https://rpc.paseo.io
MOONBASE_RPC_URL=https://rpc.api.moonbase.moonbeam.network

# Network to deploy to (use one of: polkadotHub, polkadotHubTestnet, moonbase)
NETWORK=polkadotHubTestnet
